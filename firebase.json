{
  "hosting": {
    "site": "pandishu-web-1d860",
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/tienda",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/catalogo",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/checkout",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/pedidos",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/pedido",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/admin",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/success",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/failure",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/pending",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/order-confirmation",
        "destination": "/",
        "type": 301
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}