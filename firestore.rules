rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Growth Marketing: Lead Generation (Newsletter)
    match /newsletter_leads/{leadId} {
      allow read: if false;

      // Permitir crear prospectos solo si envían los campos requeridos por UI y LFPDPPP
      allow create: if request.resource.data.nombre is string
                    && request.resource.data.correo is string
                    && request.resource.data.aceptaAviso == true;

      allow update, delete: if false;
    }

    // B2B Lead Generation: Quote Requests
    match /b2b_leads/{leadId} {
      allow read: if false;

      allow create: if request.resource.data.empresa is string
                    && request.resource.data.contacto is string
                    && request.resource.data.email is string
                    && request.resource.data.telefono is string
                    && request.resource.data.solucion is string
                    && request.resource.data.aceptaAviso == true;

      allow update, delete: if false;
    }

    // Otras reglas predeterminadas preventivas (Secure by Default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
